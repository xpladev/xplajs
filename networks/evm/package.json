{
  "name": "@xpla/evm",
  "version": "1.8.1",
  "description": "Chain definition and precompile addresses/ABIs for XPLA EVM (viem)",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./precompiles": {
      "import": "./dist/precompiles/index.js",
      "require": "./dist/precompiles/index.cjs",
      "types": "./dist/precompiles/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "xpla",
    "evm",
    "viem",
    "precompiles",
    "blockchain"
  ],
  "author": "Joowon Yun <joowon@delightlabs.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xpladev/xplajs.git",
    "directory": "networks/evm"
  },
  "bugs": {
    "url": "https://github.com/xpladev/xplajs/issues"
  },
  "homepage": "https://github.com/xpladev/xplajs#readme",
  "peerDependencies": {
    "viem": "2.x"
  },
  "dependencies": {
    "@xpla/contracts": "1.9.0-rc3",
    "cosmos-evm-contracts": "^0.0.7"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "catalog:",
    "tsdown": "catalog:",
    "viem": "^2.21.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ]
}
