{
  "name": "xplajs",
  "version": "1.9.0",
  "private": true,
  "type": "module",
  "main": "index.js",
  "repository": "git@github.com:xpladev/xplajs.git",
  "scripts": {
    "proto": "telescope download --config ./scripts/xpla.protod.config.json",
    "codegen": "tsx ./scripts/codegen.cts && pnpm run codegen:fix",
    "codegen:fix": "eslint --config eslint.codegen.config.js --fix libs/*/src networks/*/src",
    "typecheck": "pnpm -r run typecheck",
    "build": "lerna run build --stream",
    "test:module": "pnpm --filter @xpla/e2e run test:module",
    "test:starship": "pnpm --filter @xpla/e2e run test:starship",
    "starship:run": "pnpm --filter @xpla/e2e run starship:run",
    "starship:clean": "pnpm --filter @xpla/e2e run starship:clean"
  },
  "workspaces": [
    "e2e",
    "libs/*",
    "networks/*"
  ],
  "author": "Joowon Yun <joowon@delightlabs.io>",
  "license": "MIT",
  "description": "",
  "devDependencies": {
    "@chain-registry/client": "1.18.1",
    "@chain-registry/v2": "^1.71.216",
    "@hyperweb/telescope": "^2.2.4",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "deepmerge": "4.2.2",
    "eslint": "^10.0.2",
    "lerna": "catalog:",
    "rimraf": "4.4.1",
    "tsdown": "catalog:",
    "tsx": "4.21.0",
    "typescript": "catalog:",
    "typescript-eslint": "^8.56.1"
  },
  "pnpm": {
    "overrides": {
      "libsodium-wrappers-sumo": "0.8.0",
      "libsodium-sumo": "0.8.0"
    }
  },
  "packageManager": "pnpm@10.30.3"
}
